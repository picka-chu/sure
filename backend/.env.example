# Supabase Database (replace with your Supabase project credentials)
# Get these from: Supabase Dashboard > Project Settings > Database > Connection string
# Use the "URI" version with asyncpg driver
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:5432/postgres
DATABASE_SSL=true

SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REDIS_URL=redis://localhost:6379/0
STRIPE_API_KEY=sk_test_...
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=./uploads
